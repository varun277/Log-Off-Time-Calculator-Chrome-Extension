{
  "manifest_version": 3,
  "name": "Work Hours Calculator",
  "version": "1.0",
  "description": "Calculate logout time and get notified when work hours are done.",
  "permissions": [
    "notifications",
    "alarms",
    "storage"
  ],
  "icons":{
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Work Hours Calculator"
  },
  "background": {
    "service_worker": "background.js"
  }
}
